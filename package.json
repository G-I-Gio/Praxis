{
  "name": "praxis",
  "version": "0.0.3.2",
  "type": "module",
  "scripts": {
    "hash-password": "pnpm --filter @razzia/socket hash-password",
    "dev": "dotenv -e .env -- pnpm -r --parallel dev",
    "dev:web": "dotenv -e .env -- pnpm --filter web dev",
    "dev:socket": "dotenv -e .env -- pnpm --filter socket dev",
    "build": "pnpm -r run build",
    "start": "pnpm -r --parallel run start",
    "clean": "pnpm -r exec rm -rf dist node_modules",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "prettier --check . --log-level warn",
    "format:fix": "prettier --write . --log-level warn"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "latest",
    "dotenv-cli": "^11.0.0",
    "oxlint": "latest",
    "oxlint-tsgolint": "^0.23.0",
    "prettier": "^3.8.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3"
  }
}