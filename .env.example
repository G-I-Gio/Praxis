# ============================================================
# Praxis — Variables d'environnement
# Copier ce fichier en .env et ajuster les valeurs
# NE PAS versionner le fichier .env
# ============================================================

# ── Réseau ───────────────────────────────────────────────────────────────────
# Port exposé sur l'hôte (le conteneur écoute toujours sur 3000 en interne)
PORT=3000

# ── Utilisateur d'exécution ───────────────────────────────────────────────────
# UID/GID sous lequel le conteneur s'exécute
# Linux : obtenir les valeurs avec :  id -u  et  id -g
# Doit correspondre au propriétaire du dossier ./config sur l'hôte
# Windows/macOS avec Docker Desktop : laisser à 1000
PUID=1000
PGID=1000

# ── Uploads ───────────────────────────────────────────────────────────────────
# Taille maximale des fichiers uploadés (logo, favicon, sons…) en Mo
# nginx sera configuré à MAX_UPLOAD_SIZE x 1.25 automatiquement
# Exemple : 10 → nginx accepte jusqu'à 12m, Node valide à 10 Mo
MAX_UPLOAD_SIZE=10

# Taille maximale par fichier média des quiz (images, vidéos, audios) en Mo
# Indépendant de MAX_UPLOAD_SIZE (branding)
# nginx prend le max(MAX_UPLOAD_SIZE, MAX_MEDIA_SIZE) x 1.25 automatiquement
MAX_MEDIA_SIZE=20

# ── Reverse proxy ─────────────────────────────────────────────────────────────
# IPs ou CIDRs des reverse-proxies de confiance, séparés par des virgules
# Utilisé pour résoudre l'IP réelle du client depuis X-Forwarded-For
# 127.0.0.1 et ::1 (nginx interne) sont toujours inclus automatiquement
#
# Laisser vide si Praxis est exposé directement sans proxy externe
#
# Exemples :
#   Reverse-proxy sur la même machine :   KNOWN_PROXIES=192.168.1.10
#   Réseau Docker interne :               KNOWN_PROXIES=172.16.0.0/12
#   Plusieurs proxies / plages :          KNOWN_PROXIES=10.0.0.1,192.168.0.0/24
#   Cloudflare (IPv4) :
#     KNOWN_PROXIES=173.245.48.0/20,103.21.244.0/22,103.22.200.0/22,103.31.4.0/22,141.101.64.0/18,108.162.192.0/18,190.93.240.0/20,188.114.96.0/20,197.234.240.0/22,198.41.128.0/17,162.158.0.0/15,104.16.0.0/13,104.24.0.0/14,172.64.0.0/13,131.0.72.0/22
#   Cloudflare (IPv6 à ajouter si besoin) :
#     2400:cb00::/32,2606:4700::/32,2803:f800::/32,2405:b500::/32,2405:8100::/32,2a06:98c0::/29,2c0f:f248::/32
KNOWN_PROXIES=

# ── Sécurité ──────────────────────────────────────────────────────────────────
# Flag Secure sur le cookie de session (défaut : true)
# Mettre à false uniquement pour un développement local en HTTP pur (sans HTTPS)
# En production derrière nginx ou un reverse-proxy HTTPS, laisser à true (ou vide)
#COOKIE_SECURE=true

# ── Logs ──────────────────────────────────────────────────────────────────────
# Niveau minimum des logs applicatifs (Node)
# Valeurs possibles : debug | info | warn | error
# Note : le niveau "audit" (actions sensibles) est toujours actif
LOG_LEVEL=info

# Format de sortie des logs
# json   : une ligne JSON par événement — recommandé en production
#          compatible Loki, Datadog, ELK, etc.
# pretty : sortie colorée lisible — recommandé en développement local
LOG_FORMAT=json
